---
interface Props {
  code:        string
  title:       string
  message:     string
  cta:         string
  colorClass?: 'text-neon-glow-blue' | 'text-neon-glow-pink' | 'text-neon-glow-green'
}

const { code, title, message, cta, colorClass = 'text-neon-glow-blue' } = Astro.props
---

<section class="error-display">
  <span class="error-display__line error-display__line--top" aria-hidden="true"></span>

  <p class:list={['error-display__code', colorClass]}>{code}</p>

  <h1 class="error-display__title">{title}</h1>

  <p class="error-display__message">{message}</p>

  <span class="error-display__line error-display__line--bottom" aria-hidden="true"></span>

  <a href="https://www.azanolabs.com" class="error-display__cta">{cta}</a>
</section>

<style>
  .error-display {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    gap: 2rem;
  }

  /* Líneas decorativas */
  .error-display__line {
    display: block;
    width: 12rem;
    height: 2px;
    border-radius: 2px;
  }

  .error-display__line--top {
    background: linear-gradient(90deg, var(--neon-pink), var(--neon-blue));
    box-shadow:
      0 0 4px var(--neon-pink),
      0 0 8px var(--neon-blue),
      0 0 12px var(--neon-pink-glow),
      0 0 16px var(--neon-blue-glow);
  }

  .error-display__line--bottom {
    background: var(--neon-pink);
    box-shadow:
      0 0 4px var(--neon-pink),
      0 0 8px var(--neon-pink),
      0 0 12px var(--neon-pink-glow);
    opacity: 0.4;
  }

  /* Código de error */
  .error-display__code {
    font-family: var(--font-orbitron);
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1;
    margin: 0;
  }

  @media (min-width: 440px) {
    .error-display__code { font-size: 3rem; }
  }

  @media (min-width: 1200px) {
    .error-display__code { font-size: 3.75rem; }
  }

  /* Título */
  .error-display__title {
    font-family: var(--font-audiowide);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--foreground);
    text-align: center;
    margin: 0;
  }

  @media (min-width: 440px) {
    .error-display__title { font-size: 1.5rem; }
  }

  @media (min-width: 1200px) {
    .error-display__title { font-size: 1.875rem; }
  }

  /* Mensaje */
  .error-display__message {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--foreground);
    opacity: 0.6;
    text-align: center;
    max-width: 20rem;
    margin: 0;
    line-height: 1.6;
  }

  @media (min-width: 440px) {
    .error-display__message { font-size: 1rem; }
  }

  /* Botón CTA — neon-pink con hover, idéntico a azanolabs-web */
  .error-display__cta {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: rgba(var(--ch-pink), 0.7);
    border: 1px solid rgba(var(--ch-pink), 0.3);
    border-radius: 0.375rem;
    padding: 0.5rem 1.5rem;
    text-decoration: none;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .error-display__cta:hover {
    color: var(--neon-pink);
    border-color: var(--neon-pink);
  }
</style>
